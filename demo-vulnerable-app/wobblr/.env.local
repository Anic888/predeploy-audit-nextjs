# =====================================================================
# THIS FILE IS DELIBERATELY COMMITTED TO GIT IN THIS DEMO REPO ONLY.
# Every value below is a fake placeholder. None of these credentials
# are real. Do NOT use this file as a template for any real project.
# Real apps must never commit .env.local — see README.md.
# =====================================================================

NEXT_PUBLIC_SUPABASE_URL=https://wobblr-demo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJDEMOFAKEKEY12345QQQQ

# BUG (V3 / C4): the OpenAI key is prefixed NEXT_PUBLIC_, which embeds it
# into the client JavaScript bundle at build time. This is the canonical
# vibe-coded mistake.
NEXT_PUBLIC_OPENAI_API_KEY=sk-proj-DEMOFAKEKEY12345QQQQ

SUPABASE_SERVICE_ROLE_KEY=eyJDEMOFAKEKEY12345QQQQ

# BUG (V2 / C3): a live-format Stripe secret in a tracked file. The C1
# check will report the file existence; C3 will additionally call out
# this specific key so the user knows to rotate it immediately.
# Tail is exactly 20 chars (our C3 regex minimum), well below the real
# Stripe live-key length, so it cannot possibly authenticate.
STRIPE_SECRET_KEY=sk_live_DEMOFAKEKEY12345QQQQ

STRIPE_WEBHOOK_SECRET=whsec_DEMOFAKEKEY12345QQQQ

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_DEMOFAKEKEY12345QQQQ
